{
  "name": "whoop-mcp",
  "version": "1.0.0",
  "description": "MCP server for WHOOP v2 API — query recovery, sleep, workouts, cycles, and profile data",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "whoop-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "auth": "tsx scripts/auth.ts",
    "prepare": "npm run build"
  },
  "keywords": ["mcp", "whoop", "fitness", "health", "recovery", "sleep"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^16.4.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@vercel/node": "^5.1.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": "20.x"
  }
}
