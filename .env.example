WHOOP_CLIENT_ID=your_client_id_here
WHOOP_CLIENT_SECRET=your_client_secret_here

# Local stdio MCP (default)
WHOOP_REDIRECT_URI=http://localhost:8080/callback

# Remote MCP on Vercel — use your production callback URL
# WHOOP_REDIRECT_URI=https://<your-vercel-project>.vercel.app/api/oauth/callback

# Token storage: file (local default) or redis (Vercel / remote)
# TOKEN_STORE=file
# TOKEN_STORE=redis

# Upstash Redis (Vercel Marketplace) — required for remote OAuth + token storage
# UPSTASH_REDIS_REST_URL=https://<id>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token
